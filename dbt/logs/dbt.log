    as (

with costos_insumos as (
    select
        da.nombre_sucursal_asociada as nombre_sucursal,
        sum(m.monto_total_movimiento) as costo_total_insumos,
        sum(m.cantidad_movimiento) as cantidad_total_insumos
    from HGC_DW.GOLD.fact_movimientos_inventario m
    join HGC_DW.GOLD.dim_almacen da on m.id_almacen_sk = da.id_almacen_sk
    -- Solo movimientos de salida/consumo (ajustar segun tipos de movimiento reales)
    where m.monto_total_movimiento > 0
    group by 1
),

ventas_sucursal as (
    select
        nombre_sucursal,
        sum(ingreso_bruto) as venta_total,
        count(distinct id_fecha_sk) as dias_operacion
    from HGC_DW.GOLD.mart_ventas_historicas
    group by 1
)

select
    v.nombre_sucursal,
    v.venta_total,
    c.costo_total_insumos,
    -- Ratio simple de eficiencia (Venta por peso invertido en insumos)
    v.venta_total / nullif(c.costo_total_insumos, 0) as ratio_eficiencia,
    -- Normalizacion por dia
    v.venta_total / nullif(v.dias_operacion, 0) as venta_diaria_promedio,
    c.costo_total_insumos / nullif(v.dias_operacion, 0) as costo_insumo_diario_promedio
from ventas_sucursal v
join costos_insumos c on v.nombre_sucursal = c.nombre_sucursal
    )

