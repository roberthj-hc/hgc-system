    as (

/*
    DATASET: obt_price_elasticity
    --------------------------------
    Dataset diario para análisis de impacto de precios en ventas y ganancias.
    
    Los precios base son fijos en la data actual, por lo que el análisis
    se centra en:
      1. Variación natural del volumen de demanda
      2. Revenue por unidad (varía por mix de transacciones)
      3. Simulación de escenarios de cambio de precio usando elasticidades calibradas
      4. Modelo VAR sobre volumen, revenue y margen (que SÍ varían)
    
    Tipo: Series temporales + Simulación de escenarios
*/

select
    fecha_venta,
    id_producto_nk,
    nombre_producto,
    categoria_nombre,
    tipo_producto,

    -- FEATURES: Precio y costos
    precio_unitario_dia as feature_precio_unitario,
    precio_base_historico as feature_precio_base,
    costo_estandar_historico as feature_costo_estandar,
    revenue_por_unidad_dia as feature_revenue_por_unidad,

    -- FEATURES: Volumen (VARÍA diariamente)
    cantidad_vendida_dia as feature_cantidad_vendida,
    num_transacciones_dia as feature_num_transacciones,
    unidades_por_transaccion_dia as feature_unidades_por_transaccion,

    -- FEATURES: Revenue (VARÍA diariamente)
    revenue_bruto_dia as feature_revenue_bruto,
    revenue_neto_dia as feature_revenue_neto,
    ticket_promedio_dia as feature_ticket_promedio,

    -- FEATURES: Margen (VARÍA diariamente)
    margen_estimado_dia as feature_margen_estimado,
    margen_porcentual_dia as feature_margen_porcentual

from HGC_DW.SILVER.int_ventas_precios_diarios
    )

/* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "hgc_dbt", "target_name": "dev", "node_id": "model.my_new_project.obt_price_elasticity"} */;
[0m03:47:06.327749 [debug] [Thread-4 (]: Opening a new connection, currently in state init
[0m03:47:06.333165 [debug] [Thread-3 (]: Using snowflake connection "model.my_new_project.feat_precio_elasticidad"
[0m03:47:06.334367 [debug] [Thread-3 (]: On model.my_new_project.feat_precio_elasticidad: create or replace transient table HGC_DW.features.feat_precio_elasticidad
    
    
    
    as (

/*
    FEATURES: feat_precio_elasticidad
    -----------------------------------
    Calcula features de elasticidad de precios por producto para
    alimentar modelos VAR y simulación de escenarios de pricing.
    
    Features calculados:
      - Estadísticas de precio y volumen
      - Elasticidad precio-demanda estimada (correlación)
      - Tendencias temporales (7d, 30d, 90d)
      - Métricas de margen y sensibilidad
*/

with diario as (
    select * from HGC_DW.SILVER.int_ventas_precios_diarios
),

-- Estadísticas globales por producto
stats_producto as (
    select
        id_producto_nk,
        nombre_producto,
        categoria_nombre,
        tipo_producto,
        precio_base_historico,
        costo_estandar_historico,

        -- Rango temporal
        min(fecha_venta) as primera_venta,
        max(fecha_venta) as ultima_venta,
        count(distinct fecha_venta) as dias_con_ventas,

        -- Estadísticas de volumen
        avg(cantidad_vendida_dia) as volumen_promedio_diario,
        stddev(cantidad_vendida_dia) as volumen_desviacion_std,
        sum(cantidad_vendida_dia) as volumen_total_historico,

        -- Estadísticas de precio efectivo
        avg(precio_promedio_dia) as precio_efectivo_promedio,
        stddev(precio_promedio_dia) as precio_desviacion_std,
        min(precio_promedio_dia) as precio_efectivo_minimo,
        max(precio_promedio_dia) as precio_efectivo_maximo,

        -- Revenue y margen
        sum(revenue_neto_dia) as revenue_neto_total,
        sum(margen_estimado_dia) as margen_total,
        avg(margen_porcentual_dia) as margen_porcentual_promedio,

        -- Descuentos
        avg(tasa_descuento_dia) as tasa_descuento_promedio,
        sum(descuento_total_dia) as descuento_total_historico,

        -- Elasticidad estimada: correlación entre variación de precio y cantidad
        -- Pearson: corr(precio, cantidad)
        corr(precio_promedio_dia, cantidad_vendida_dia) as correlacion_precio_cantidad,

        -- Transacciones
        avg(num_transacciones_dia) as transacciones_promedio_dia

    from diario
    group by 1, 2, 3, 4, 5, 6
),

-- Tendencias recientes por producto
tendencias as (
    select
        id_producto_nk,
        
        -- Volumen reciente
        avg(case when fecha_venta >= dateadd(day, -7, current_date()) then cantidad_vendida_dia end) as volumen_promedio_7d,
        avg(case when fecha_venta >= dateadd(day, -30, current_date()) then cantidad_vendida_dia end) as volumen_promedio_30d,
        avg(case when fecha_venta >= dateadd(day, -90, current_date()) then cantidad_vendida_dia end) as volumen_promedio_90d,

        -- Precio reciente
        avg(case when fecha_venta >= dateadd(day, -7, current_date()) then precio_promedio_dia end) as precio_promedio_7d,
        avg(case when fecha_venta >= dateadd(day, -30, current_date()) then precio_promedio_dia end) as precio_promedio_30d,
        avg(case when fecha_venta >= dateadd(day, -90, current_date()) then precio_promedio_dia end) as precio_promedio_90d,

        -- Revenue reciente
        sum(case when fecha_venta >= dateadd(day, -30, current_date()) then revenue_neto_dia else 0 end) as revenue_neto_30d,
        sum(case when fecha_venta >= dateadd(day, -90, current_date()) then revenue_neto_dia else 0 end) as revenue_neto_90d,

        -- Margen reciente
        avg(case when fecha_venta >= dateadd(day, -30, current_date()) then margen_porcentual_dia end) as margen_promedio_30d

    from diario
    group by 1
)

select
    sp.id_producto_nk,
    sp.nombre_producto,
    sp.categoria_nombre,
    sp.tipo_producto,
    sp.precio_base_historico,
    sp.costo_estandar_historico,

    -- Features de volumen
    sp.dias_con_ventas,
    round(sp.volumen_promedio_diario, 2) as volumen_promedio_diario,
    round(coalesce(sp.volumen_desviacion_std, 0), 2) as volumen_desviacion_std,
    sp.volumen_total_historico,
    round(sp.transacciones_promedio_dia, 2) as transacciones_promedio_dia,

    -- Features de precio
    round(sp.precio_efectivo_promedio, 2) as precio_efectivo_promedio,
    round(coalesce(sp.precio_desviacion_std, 0), 4) as precio_desviacion_std,
    sp.precio_efectivo_minimo,
    sp.precio_efectivo_maximo,

    -- Variabilidad de precios
    round(
        case 
            when sp.precio_efectivo_promedio > 0 
            then coalesce(sp.precio_desviacion_std, 0) / sp.precio_efectivo_promedio 
            else 0 
        end, 4
    ) as coeficiente_variacion_precio,

    -- Features de elasticidad
    round(coalesce(sp.correlacion_precio_cantidad, 0), 4) as elasticidad_precio_demanda,

    -- Revenue y margen
    round(sp.revenue_neto_total, 2) as revenue_neto_total,
    round(sp.margen_total, 2) as margen_total,
    round(sp.margen_porcentual_promedio, 4) as margen_porcentual_promedio,
    round(sp.tasa_descuento_promedio, 4) as tasa_descuento_promedio,
    round(sp.descuento_total_historico, 2) as descuento_total_historico,

    -- Tendencias de volumen
    round(coalesce(t.volumen_promedio_7d, 0), 2) as volumen_promedio_7d,
    round(coalesce(t.volumen_promedio_30d, 0), 2) as volumen_promedio_30d,
    round(coalesce(t.volumen_promedio_90d, 0), 2) as volumen_promedio_90d,
    round(
        case 
            when coalesce(t.volumen_promedio_30d, 0) > 0 
            then (coalesce(t.volumen_promedio_7d, 0) - t.volumen_promedio_30d) / t.volumen_promedio_30d
            else 0 
        end, 4
    ) as tendencia_volumen_7d_vs_30d,

    -- Tendencias de precio
    round(coalesce(t.precio_promedio_7d, 0), 2) as precio_promedio_7d,
    round(coalesce(t.precio_promedio_30d, 0), 2) as precio_promedio_30d,
    round(coalesce(t.precio_promedio_90d, 0), 2) as precio_promedio_90d,

    -- Revenue reciente
    round(coalesce(t.revenue_neto_30d, 0), 2) as revenue_neto_30d,
    round(coalesce(t.revenue_neto_90d, 0), 2) as revenue_neto_90d,
    round(coalesce(t.margen_promedio_30d, 0), 4) as margen_promedio_30d,

    -- Metadata temporal
    sp.primera_venta,
    sp.ultima_venta

from stats_producto sp
left join tendencias t on sp.id_producto_nk = t.id_producto_nk
    )

