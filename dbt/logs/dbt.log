    as (

/*
    DATASET: obt_price_elasticity
    --------------------------------
    Dataset final para análisis de elasticidad de precios y
    simulación de escenarios de pricing con modelos VAR.
    
    Objetivo: Entender cómo cambios en precios afectan ventas y margen.
    
    Resultado esperado:
      "Subir precios 5% → ventas -2%, margen +3%"
    
    Tipo: Series temporales + Regresión (VAR multivariado)
    
    Nota: Este OBT incluye datos diarios (no agregados) para permitir
    el análisis de series temporales en el notebook.
*/

select
    fecha_venta,
    id_producto_nk,
    nombre_producto,
    categoria_nombre,
    tipo_producto,

    -- FEATURES: Precio
    precio_promedio_dia as feature_precio_efectivo,
    precio_base_historico as feature_precio_base,
    variacion_precio_vs_base as feature_variacion_precio_pct,
    tasa_descuento_dia as feature_tasa_descuento,

    -- FEATURES: Volumen
    cantidad_vendida_dia as feature_cantidad_vendida,
    num_transacciones_dia as feature_num_transacciones,

    -- FEATURES: Revenue
    revenue_bruto_dia as feature_revenue_bruto,
    revenue_neto_dia as feature_revenue_neto,
    descuento_total_dia as feature_descuento_total,

    -- FEATURES: Margen y Costos
    margen_estimado_dia as feature_margen_estimado,
    margen_porcentual_dia as feature_margen_porcentual,
    costo_estandar_historico as feature_costo_estandar

from HGC_DW.SILVER.int_ventas_precios_diarios
    )

/* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "hgc_dbt", "target_name": "dev", "node_id": "model.my_new_project.obt_price_elasticity"} */;
