ventas_sucursal as (
    select
        nombre_sucursal,
        sum(ventas_reales) as venta_total,
        count(distinct fecha) as dias_operacion
    from HGC_DW.GOLD.mart_ventas_historicas
    group by 1
)

select
    v.nombre_sucursal,
    v.venta_total,
    c.costo_total_insumos,
    -- Ratio simple de eficiencia (Venta por peso invertido en insumos)
    v.venta_total / nullif(c.costo_total_insumos, 0) as ratio_eficiencia,
    -- Normalizacion por dia
    v.venta_total / nullif(v.dias_operacion, 0) as venta_diaria_promedio,
    c.costo_total_insumos / nullif(v.dias_operacion, 0) as costo_insumo_diario_promedio
from ventas_sucursal v
join costos_insumos c on v.nombre_sucursal = c.nombre_sucursal
    )

