    as (

with base_ventas as (
    select
        v.id_producto_sk,
        v.id_sucursal_sk,
        p.nombre_producto,
        s.nombre_sucursal,
        s.tipo_formato,
        (v.monto_subtotal_neto / nullif(v.cantidad_vendida, 0)) as precio,
        sum(v.cantidad_vendida) as cantidad,
        sum(v.monto_subtotal_neto) as ingreso_neto
    from HGC_DW.GOLD.fact_ventas_detalle v
    join HGC_DW.GOLD.dim_producto p on v.id_producto_sk = p.id_producto_sk
    join HGC_DW.GOLD.dim_sucursal s on v.id_sucursal_sk = s.id_sucursal_sk
    where v.monto_subtotal_neto > 0
    group by 1, 2, 3, 4, 5, 6
),

promedios_tipo_formato as (
    select
        id_producto_sk,
        tipo_formato,
        avg(cantidad) as avg_q_tipo
    from base_ventas
    group by 1, 2
)

select
    b.id_producto_sk,
    b.nombre_producto,
    b.id_sucursal_sk,
    b.nombre_sucursal,
    b.tipo_formato,
    b.precio,
    b.cantidad,
    b.ingreso_neto,
    -- Normalización para evitar sesgos por tamaño de sucursal
    b.cantidad / nullif(p.avg_q_tipo, 0) as cantidad_normalizada,
    ln(nullif(b.precio, 0)) as log_p,
    ln(nullif(b.cantidad / nullif(p.avg_q_tipo, 0), 0)) as log_q_norm
from base_ventas b
join promedios_tipo_formato p 
    on b.id_producto_sk = p.id_producto_sk 
    and b.tipo_formato = p.tipo_formato
    )

/* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "hgc_dbt", "target_name": "dev", "node_id": "model.my_new_project.mart_econometria_elasticidad_base"} */;
